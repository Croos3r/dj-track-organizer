{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Track Organizer",
  "version": "0.1.0",
  "identifier": "com.dorian.track-organizer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Track Organizer",
        "width": 980,
        "height": 720,
        "minWidth": 760,
        "minHeight": 560,
        "center": true,
        "backgroundColor": "#0b0b10"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
